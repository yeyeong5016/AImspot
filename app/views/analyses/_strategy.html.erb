<%# AI 차별화 전략 — 체크박스 토글 + 동적 % 계산 (strategy_controller) %>
<div class="space-y-4" data-controller="strategy">
  <div>
    <div class="mb-3 flex items-center gap-2">
      <span class="text-sm font-medium text-brand">AI 차별화 전략</span>
      <span class="text-xs text-muted-foreground">적용할 전략을 선택하면 예상 매출이 갱신됩니다</span>
    </div>

    <div class="grid gap-4 md:grid-cols-3">
      <% strategies.each do |s| %>
        <button type="button"
                data-strategy-target="card"
                data-id="<%= s[:id] %>"
                data-boost="<%= s[:boost] %>"
                data-on="<%= s[:default_on] ? 'true' : 'false' %>"
                data-action="click->strategy#toggle"
                class="relative rounded-2xl p-5 text-left transition">
          <!-- 체크박스 -->
          <span data-strategy-target="check"
                class="absolute left-4 top-4 flex h-5 w-5 items-center justify-center rounded-md border transition">
            <svg data-strategy-target="checkIcon" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#ffffff" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="hidden"><polyline points="20 6 9 17 4 12"/></svg>
          </span>

          <!-- 순위 배지 -->
          <span data-strategy-target="badge"
                class="absolute right-4 top-4 hidden rounded-full px-2.5 py-1 text-xs font-semibold text-white"
                style="background:#18181b"></span>

          <span class="ml-7 flex h-10 w-10 items-center justify-center rounded-full bg-brand-soft text-xl"><%= s[:icon] %></span>
          <h3 class="mt-3 flex items-center gap-2 font-bold">
            <%= s[:title] %>
            <span class="text-sm font-semibold text-brand">+<%= s[:boost] %>%</span>
          </h3>
          <p class="mt-2 text-sm leading-relaxed text-muted-foreground"><%= s[:body] %></p>
          <div class="mt-4 inline-flex rounded-full bg-[var(--color-zinc-bg)] px-3 py-1.5 text-xs font-medium text-muted-foreground"><%= s[:chip] %></div>
        </button>
      <% end %>
    </div>
  </div>

  <!-- 동적 결과 카드 -->
  <div class="rounded-2xl border-l-4 border-l-brand bg-ink p-6 text-[var(--color-primary-foreground)]">
    <div class="flex items-center gap-2">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#3b82f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12 3-1.9 5.8a2 2 0 0 1-1.3 1.3L3 12l5.8 1.9a2 2 0 0 1 1.3 1.3L12 21l1.9-5.8a2 2 0 0 1 1.3-1.3L21 12l-5.8-1.9a2 2 0 0 1-1.3-1.3Z"/></svg>
      <span class="text-xs font-semibold text-white/60">AImspot AI 최종 조언</span>
    </div>
    <p class="mt-3 text-balance text-center text-xl font-bold leading-relaxed sm:text-2xl">
      <span class="text-white">기존 동종 업계 매장 대비 월매출</span> <span class="text-brand tabular-nums" data-strategy-target="total">+0%</span> 상승
    </p>
    <p class="mt-3 text-center text-sm text-white/55" data-strategy-target="breakdown"></p>
  </div>
</div>
