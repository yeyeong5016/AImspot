<%
  # 점수 → 등급 변환
  grade =
    if    @score >= 80 then { g: "A", color: "#3b82f6", bg: "#eff6ff", label: "창업 추천" }
    elsif @score >= 60 then { g: "B", color: "#22c55e", bg: "#f0fdf4", label: "검토 가능" }
    elsif @score >= 40 then { g: "C", color: "#f59e0b", bg: "#fefce8", label: "신중 검토" }
    else                    { g: "D", color: "#ef4444", bg: "#fef2f2", label: "창업 비추천" }
    end

  stat_rows = [
    { label: "동종 업종 수", value: "64곳", sub: "반경 300m 기준" },
    { label: "유동인구", value: "24,800명", sub: "월 평균" },
    { label: "폐업률", value: "18.4%", sub: "최근 1년" }
  ]
%>

<main class="min-h-screen bg-background">
  <div class="mx-auto max-w-6xl space-y-4 px-4 py-8 sm:px-6">
    <!-- 헤더 -->
    <div class="flex flex-wrap items-end justify-between gap-4">
      <div>
        <span class="text-sm font-medium text-brand">상권 분석</span>
        <h1 class="mt-1 text-2xl font-bold tracking-tight sm:text-[28px]">AI 상권 분석 리포트</h1>
        <p class="mt-1 text-sm text-muted-foreground"><%= @area[:label] %> · <%= @biz %> · 2026년 1분기</p>
      </div>
    </div>

    <!-- Block 1 — AI 분석 결과 -->
    <div class="rounded-2xl border border-border border-l-4 border-l-brand bg-card p-6">
      <div class="flex items-center gap-2">
        <span class="flex h-7 w-7 items-center justify-center rounded-full bg-brand-soft">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#3b82f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12 3-1.9 5.8a2 2 0 0 1-1.3 1.3L3 12l5.8 1.9a2 2 0 0 1 1.3 1.3L12 21l1.9-5.8a2 2 0 0 1 1.3-1.3L21 12l-5.8-1.9a2 2 0 0 1-1.3-1.3Z"/></svg>
        </span>
        <span class="text-xs font-semibold text-muted-foreground">AIMSPOT AI</span>
        <span class="font-bold">AI 분석 결과</span>
      </div>
      <p class="mt-3 leading-relaxed text-foreground/90">
        현재 카페 업종 경쟁이 높은 편입니다. 유동인구는 충분하지만 동종 업종 밀집도가 높아 일반적인 카페로는 차별화가 어렵습니다. 학생 수요가 높은 건강식 메뉴나 심야 운영 등 명확한 차별화 전략이 필요합니다.
      </p>
      <div class="mt-4 grid gap-3 sm:grid-cols-2">
        <% @ai_bullets.each do |b| %>
          <div class="flex items-start gap-2 text-sm">
            <span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-brand"></span>
            <span class="text-muted-foreground"><%= b %></span>
          </div>
        <% end %>
      </div>
    </div>

    <!-- AI 차별화 전략 + 동적 결과 -->
    <%= render "analyses/strategy", strategies: @strategies %>

    <!-- Block 2 — 지도 + 점수 -->
    <div class="grid gap-4 lg:grid-cols-[58fr_42fr]">
      <!-- 지도 -->
      <div class="rounded-2xl border border-border bg-card p-0">
        <div class="flex items-center justify-between px-5 pt-5">
          <span class="flex items-center gap-1.5 text-sm font-medium text-muted-foreground">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#3b82f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
            <%= @area[:label] %> 상권
          </span>
          <span class="rounded-full bg-[var(--color-zinc-bg)] px-2.5 py-1 text-xs font-medium text-muted-foreground">반경 300m</span>
        </div>
        <div class="mt-3 h-[320px] overflow-hidden px-5">
          <div class="h-full w-full rounded-xl"
               data-controller="map"
               data-map-station-value="<%= @station.to_json %>"
               data-map-areas-value="<%= @areas.to_json %>"
               data-map-selected-value="<%= @code %>"></div>
        </div>
        <div class="flex items-center gap-4 px-5 py-3 text-xs text-muted-foreground">
          <span class="inline-flex items-center gap-1.5"><span class="h-2.5 w-2.5 rounded-full" style="background:#ef4444"></span> 선택 상권</span>
          <span class="inline-flex items-center gap-1.5"><span class="h-2.5 w-2.5 rounded-full border border-[#a1a1aa] bg-card"></span> 기타 상권</span>
        </div>
      </div>

      <!-- 점수 -->
      <div class="rounded-2xl border border-border bg-card p-6">
        <div class="flex items-center justify-between">
          <h3 class="font-bold">창업 종합 점수</h3>
          <span class="rounded-full bg-[var(--color-zinc-bg)] px-2.5 py-1 text-xs font-medium text-muted-foreground"><%= @biz %></span>
        </div>
        <div class="mt-6 text-center">
          <span class="text-[52px] font-bold leading-none" style="color:<%= grade[:color] %>"><%= @score %>점</span>
        </div>
        <div class="mt-5">
          <div class="h-2.5 w-full overflow-hidden rounded-full bg-[#e4e4e7]">
            <div class="h-full rounded-full" style="width:<%= @score %>%;background-color:<%= grade[:color] %>"></div>
          </div>
          <div class="mt-1.5 flex justify-between text-xs text-muted-foreground"><span>낮음</span><span>높음</span></div>
        </div>
        <div class="mt-4 flex justify-center">
          <span class="rounded-full px-3 py-1.5 text-sm font-semibold" style="background-color:<%= grade[:bg] %>;color:<%= grade[:color] %>">
            <%= grade[:g] %>등급 · <%= grade[:label] %>
          </span>
        </div>
        <div class="my-5 h-px w-full bg-border"></div>
        <div class="space-y-3">
          <% stat_rows.each do |r| %>
            <div class="flex items-center justify-between">
              <span class="flex items-center gap-2 text-sm text-muted-foreground"><%= r[:label] %></span>
              <span class="text-right">
                <span class="font-bold"><%= r[:value] %></span>
                <span class="ml-2 text-xs text-muted-foreground"><%= r[:sub] %></span>
              </span>
            </div>
          <% end %>
        </div>
      </div>
    </div>

    <!-- Block 3 — 점포당 월매출 순위 -->
    <div class="rounded-2xl border border-border bg-card p-6">
      <div class="mb-4 flex items-center justify-between gap-3">
        <span class="text-xs font-semibold uppercase tracking-wide text-muted-foreground">시장성</span>
        <span class="rounded-full px-2.5 py-1 text-xs font-semibold" style="background:#f0fdf4;color:#16a34a">중상위</span>
      </div>
      <div class="h-[360px]"><canvas data-controller="chart" data-chart-type-value="revenue" data-chart-data-value="<%= @revenue.to_json %>"></canvas></div>
      <div class="mt-4 flex flex-wrap gap-2">
        <span class="inline-flex items-center rounded-full bg-[var(--color-zinc-bg)] px-3 py-1.5 text-xs font-medium text-foreground">점포당 월매출 39백만원</span>
        <span class="inline-flex items-center rounded-full bg-[var(--color-zinc-bg)] px-3 py-1.5 text-xs font-medium text-foreground">전체 업종 중 5위</span>
      </div>
    </div>

    <!-- Block 4 — 경쟁도 -->
    <div class="rounded-2xl border border-border bg-card p-6">
      <div class="mb-4 flex items-center justify-between gap-3">
        <span class="text-xs font-semibold uppercase tracking-wide text-muted-foreground">경쟁도</span>
        <span class="rounded-full px-2.5 py-1 text-xs font-semibold" style="background:#fef2f2;color:#ef4444">경쟁 과열</span>
      </div>
      <p class="mb-2 text-center text-sm font-semibold">F&amp;B 중앙값의 약 4.6배 · 경쟁 과열</p>
      <div class="h-[280px]"><canvas data-controller="chart" data-chart-type-value="competition" data-chart-data-value="<%= @competition.to_json %>"></canvas></div>
      <div class="mt-4 flex flex-wrap gap-2">
        <span class="inline-flex items-center rounded-full bg-[var(--color-zinc-bg)] px-3 py-1.5 text-xs font-medium text-foreground">동종 점포 64개</span>
        <span class="inline-flex items-center rounded-full bg-[var(--color-zinc-bg)] px-3 py-1.5 text-xs font-medium text-foreground">중앙값의 4.6배</span>
        <span class="inline-flex items-center rounded-full bg-[var(--color-zinc-bg)] px-3 py-1.5 text-xs font-medium text-foreground">프랜차이즈 38%</span>
      </div>
    </div>

    <!-- Block 5 — 연령대별 매출 비중 -->
    <div class="rounded-2xl border border-border bg-card p-6">
      <div class="mb-4 flex items-center justify-between gap-3">
        <span class="text-xs font-semibold uppercase tracking-wide text-muted-foreground">학생 적합도</span>
        <span class="rounded-full px-2.5 py-1 text-xs font-semibold" style="background:#f0fdf4;color:#16a34a">학생 친화</span>
      </div>
      <div class="h-[280px]"><canvas data-controller="chart" data-chart-type-value="age" data-chart-data-value="<%= @age.to_json %>" data-chart-avg-value="<%= @age_average %>"></canvas></div>
      <div class="mt-4 flex flex-wrap gap-2">
        <span class="inline-flex items-center rounded-full bg-[var(--color-zinc-bg)] px-3 py-1.5 text-xs font-medium text-foreground">20대 매출 비중 25% (평균 +6%p)</span>
        <span class="inline-flex items-center rounded-full bg-[var(--color-zinc-bg)] px-3 py-1.5 text-xs font-medium text-foreground">여성 매출 비중 68%</span>
      </div>
    </div>

    <!-- Block 6 — 시간대별 매출 vs 학생 이용 -->
    <div class="rounded-2xl border border-border bg-card p-6">
      <div class="mb-4 flex items-center justify-between gap-3">
        <span class="text-xs font-semibold uppercase tracking-wide text-muted-foreground">피크타임 분석</span>
      </div>
      <div class="mb-3 flex flex-wrap items-center gap-4 text-xs text-muted-foreground">
        <span class="inline-flex items-center gap-1.5"><span class="h-2.5 w-3.5 rounded-sm bg-[#93c5fd]"></span> 매출(M KRW)</span>
        <span class="inline-flex items-center gap-1.5"><span class="h-0.5 w-4 bg-[#ef4444]"></span> 학생 이용 응답수</span>
      </div>
      <div class="h-[300px]"><canvas data-controller="chart" data-chart-type-value="timeslot" data-chart-data-value="<%= @timeslot.to_json %>"></canvas></div>
      <div class="mt-4 flex flex-wrap gap-2">
        <span class="inline-flex items-center rounded-full bg-[var(--color-zinc-bg)] px-3 py-1.5 text-xs font-medium text-foreground">매출 피크 11~14시</span>
        <span class="inline-flex items-center rounded-full bg-[var(--color-zinc-bg)] px-3 py-1.5 text-xs font-medium text-foreground">학생 활동 피크 17~21시</span>
      </div>
    </div>

    <!-- Block 7 — 학생 수요 -->
    <div class="grid gap-4 lg:grid-cols-[55fr_45fr]">
      <div class="rounded-2xl border border-border bg-card p-6">
        <div class="mb-4"><span class="text-xs font-semibold uppercase tracking-wide text-muted-foreground">상권 문제점 TOP5</span></div>
        <div class="h-[250px]"><canvas data-controller="chart" data-chart-type-value="problems" data-chart-data-value="<%= @problems.to_json %>"></canvas></div>
      </div>
      <div class="grid gap-4">
        <div class="rounded-2xl border border-border bg-card p-6">
          <div class="mb-4"><span class="text-xs font-semibold uppercase tracking-wide text-muted-foreground">학생 선택 기준 TOP3</span></div>
          <div class="space-y-3">
            <% @choice_criteria.each do |c| %>
              <div class="flex items-center gap-3">
                <span class="flex h-7 w-9 items-center justify-center rounded-full bg-[var(--color-zinc-bg)] text-xs font-semibold"><%= c[:rank] %>위</span>
                <span class="flex-1 text-sm font-medium"><%= c[:label] %></span>
                <span class="rounded-full bg-brand-soft px-2.5 py-1 text-xs font-semibold text-brand"><%= c[:count] %>명</span>
              </div>
            <% end %>
          </div>
        </div>
        <div class="rounded-2xl border border-border bg-card p-6">
          <div class="mb-4"><span class="text-xs font-semibold uppercase tracking-wide text-muted-foreground">희망 업종 TOP3</span></div>
          <div class="space-y-3">
            <% @desired_biz.each do |c| %>
              <div class="flex items-center gap-3">
                <span class="flex h-7 w-9 items-center justify-center rounded-full bg-[var(--color-zinc-bg)] text-xs font-semibold"><%= c[:rank] %>위</span>
                <span class="flex-1 text-sm font-medium"><%= c[:label] %></span>
                <span class="rounded-full bg-brand-soft px-2.5 py-1 text-xs font-semibold text-brand"><%= c[:count] %>명</span>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </div>
</main>
