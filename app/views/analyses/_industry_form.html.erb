<%# 업종(대>중>소) 연동 선택 + 상권 선택 폼 — React state 를 form_controller(Stimulus) 로 대체 %>
<%= form_with url: report_path, method: :get,
      data: { controller: "form", form_categories_value: @categories.to_json } do %>
  <div class="rounded-2xl border border-border bg-card p-6 shadow-sm">
    <!-- 업종 선택 -->
    <label class="mb-2 block text-sm font-semibold">업종 선택</label>
    <div class="flex items-center gap-1.5">
      <!-- 대분류 -->
      <div class="relative flex-1">
        <select name="category_l" aria-label="대분류"
          data-form-target="large" data-action="change->form#changeLarge"
          class="w-full appearance-none rounded-lg border border-border bg-card px-3 py-2.5 pr-9 text-sm font-medium text-foreground outline-none transition focus:border-brand focus:ring-2 focus:ring-brand/20">
          <option value="">대분류</option>
          <% @categories.each do |c| %>
            <option value="<%= c[:label] %>"><%= c[:label] %></option>
          <% end %>
        </select>
        <span class="pointer-events-none absolute right-3 top-1/2 -translate-y-1/2 text-muted-foreground">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
        </span>
      </div>

      <svg class="h-4 w-4 shrink-0 text-muted-foreground" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>

      <!-- 중분류 -->
      <div class="relative flex-1">
        <select name="category_m" aria-label="중분류" disabled
          data-form-target="mid" data-action="change->form#changeMid"
          class="w-full appearance-none rounded-lg border border-border bg-[var(--color-zinc-bg)] px-3 py-2.5 pr-9 text-sm font-medium text-muted-foreground outline-none transition focus:border-brand focus:ring-2 focus:ring-brand/20">
          <option value="">중분류</option>
        </select>
        <span class="pointer-events-none absolute right-3 top-1/2 -translate-y-1/2 text-muted-foreground/50">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
        </span>
      </div>

      <svg class="h-4 w-4 shrink-0 text-muted-foreground" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>

      <!-- 업종(소분류) -->
      <div class="relative flex-1">
        <select name="business_type" aria-label="업종" disabled
          data-form-target="biz" data-action="change->form#changeBiz"
          class="w-full appearance-none rounded-lg border border-border bg-[var(--color-zinc-bg)] px-3 py-2.5 pr-9 text-sm font-medium text-muted-foreground outline-none transition focus:border-brand focus:ring-2 focus:ring-brand/20">
          <option value="">업종</option>
        </select>
        <span class="pointer-events-none absolute right-3 top-1/2 -translate-y-1/2 text-muted-foreground/50">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
        </span>
      </div>
    </div>

    <!-- 선택 경로 칩 -->
    <div data-form-target="chip" class="mt-3 hidden">
      <span class="inline-flex items-center rounded-full bg-[var(--color-zinc-bg)] px-3 py-1.5 text-xs font-medium text-muted-foreground" data-form-target="chipText"></span>
    </div>

    <div class="my-5 h-px w-full bg-border"></div>

    <!-- 상권 선택 -->
    <label class="mb-2 block text-sm font-semibold">상권 선택</label>
    <div class="flex flex-wrap gap-2">
      <% @trade_areas.each do |t| %>
        <label class="cursor-pointer">
          <input type="radio" name="trdar_cd" value="<%= t[:code] %>" class="peer sr-only"
                 data-form-target="area" data-action="change->form#changeArea">
          <span class="inline-block rounded-full border border-border bg-card px-3.5 py-1.5 text-sm font-medium text-foreground transition hover:border-foreground/30 peer-checked:border-ink peer-checked:bg-ink peer-checked:text-[var(--color-primary-foreground)]">
            <%= t[:label] %>
          </span>
        </label>
      <% end %>
    </div>

    <button type="submit" data-form-target="submit" disabled
      class="mt-5 flex w-full cursor-not-allowed items-center justify-center gap-2 rounded-lg bg-brand/50 px-4 py-3 text-sm font-semibold text-white transition">
      분석 시작하기
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
    </button>
  </div>
<% end %>
